# ==============================================
# EduMentor AI - Environment Configuration
# ==============================================

# --- System Context ---
ENVIRONMENT=development
# Options: development, staging, production
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR

# --- AWS Credentials (REQUIRED) ---
# Create an IAM User with access to Bedrock and CloudWatch
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- AI Model Configuration (Amazon Nova) ---
# Ensure you have requested access to these models in the AWS Bedrock Console
# https://us-east-1.console.aws.amazon.com/bedrock/home?region=us-east-1#/modelaccess
NOVA_LITE_MODEL_ID=us.amazon.nova-lite-v1:0
NOVA_SONIC_MODEL_ID=us.amazon.nova-2-sonic-v1:0
NOVA_ACT_MODEL_ID=us.amazon.nova-2-act-v1:0

# --- Database (PostgreSQL) ---
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://edumentor:password@localhost:5432/edumentor_db

# --- Monitoring & Error Tracking ---
# Sentry DSN (Get this from sentry.io)
SENTRY_DSN=

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
