# =====================================================
# EduMentor AI - Environment Configuration Template
# =====================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to version control
# =====================================================

# Environment
ENVIRONMENT=development  # development, staging, production

# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default  # or your named AWS profile

# AWS Bedrock Model IDs
ORCHESTRATOR_MODEL=us.amazon.nova-lite-v1:0
SONIC_MODEL=us.amazon.nova-2-sonic-v1:0
INSTIGATOR_MODEL=us.amazon.nova-2-act-v1:0

# AWS Credentials (Optional - prefer using AWS CLI profiles)
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Bedrock Configuration
BEDROCK_MAX_TOKENS=512
BEDROCK_TEMPERATURE=0.7
BEDROCK_TIMEOUT_SECONDS=30

# Database Configuration
# Development (SQLite)
DATABASE_URL=sqlite:///./edumentor_dev.db

# Production (PostgreSQL - uncomment when ready)
# DATABASE_URL=postgresql://username:password@host:5432/edumentor_db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true  # Set to false in production

# Security
SECRET_KEY=your-secret-key-here-change-in-production-min-32-chars
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging & Monitoring
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
CLOUDWATCH_LOG_GROUP=/edumentor/backend
SENTRY_DSN=  # Add your Sentry DSN for error tracking

# Feature Flags
ENABLE_VOICE_SYNTHESIS=false
ENABLE_EMBEDDINGS=false
ENABLE_CULTURAL_CONTEXT=true

# Session Management
SESSION_TIMEOUT_MINUTES=30
MAX_HISTORY_LENGTH=50

# Cost Control
DAILY_TOKEN_BUDGET=100000
ALERT_THRESHOLD_DOLLARS=50

# Frontend (if applicable)
NEXT_PUBLIC_API_URL=http://localhost:8000
