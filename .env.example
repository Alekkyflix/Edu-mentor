# ==============================================
# EduMentor AI - Template Configuration
# Rename this to .env and fill in your secrets
# ==============================================

# --- System Context ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- AWS Credentials (REQUIRED) ---
# 🚨 CRITICAL: Never commit your real keys to Git!
AWS_ACCESS_KEY_ID=<YOUR_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<YOUR_SECRET_ACCESS_KEY>
AWS_REGION=us-east-1

# --- AI Model Configuration (Amazon Nova) ---
NOVA_LITE_MODEL_ID=us.amazon.nova-lite-v1:0
NOVA_PRO_MODEL_ID=us.amazon.nova-pro-v1:0
NOVA_MICRO_MODEL_ID=us.amazon.nova-micro-v1:0

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://<USER>:<PASSWORD>@localhost:5432/edumentor

# --- Monitoring & Error Tracking ---
SENTRY_DSN=<YOUR_SENTRY_DSN>

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
